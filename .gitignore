# 直接创建并写入（Mac/Linux）
cat > .gitignore << EOF
# 操作系统临时文件
.DS_Store
Thumbs.db

# 日志文件
*.log
logs/

# 依赖包（根据项目类型选）
node_modules/  # Node.js项目
venv/          # Python虚拟环境
target/        # Java Maven/Gradle
vendor/        # PHP Composer

# IDE/编辑器配置
.idea/
.vscode/
*.swp
*.swo

# 构建产物
dist/
build/
EOF

# Windows用户可以直接新建文本文件，重命名为.gitignore，粘贴上述内容